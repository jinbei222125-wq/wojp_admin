{% comment %}
  WinGrow お買い得品セクション
  - 割引率（OFFバッジ）付き商品カード
  - compare_at_price から自動計算
  - wg-product-card スニペットを使用（show_off_badge: true）
{% endcomment %}

{%- liquid
  assign sale_collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_count | default: 4
-%}

<div class="wg-site">
  <section class="wg-sale">
    <div class="wg-container">

      <div class="wg-section-header">
        <img
          src="{{ 'wave_icon.png' | asset_url }}"
          alt=""
          class="wg-wave-icon"
          width="80"
          loading="lazy">
        <p class="wg-section-subtitle">{{ section.settings.subtitle }}</p>
        <h2 class="wg-section-title wg-section-title--red">{{ section.settings.title }}</h2>
      </div>

      <div class="wg-product-grid">
        {%- if sale_collection != blank -%}
          {%- for product in sale_collection.products limit: products_to_show -%}
            {% render 'wg-product-card', product: product, show_off_badge: true %}
          {%- endfor -%}
        {%- else -%}
          {%- comment %} コレクション未設定時はプレースホルダー {%- endcomment %}
          {%- for i in (1..4) -%}
            <div class="wg-product-card">
              <div class="wg-product-card__image">
                <span class="wg-off-badge">
                  <span class="wg-off-badge__percent">25</span>
                  <span class="wg-off-badge__unit">%</span>
                  <span class="wg-off-badge__text">OFF</span>
                </span>
                {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="wg-product-card__body">
                <div class="wg-product-tags">
                  <span class="wg-product-tag">新商品</span>
                  <span class="wg-product-tag">送料無料</span>
                </div>
                <h3 class="wg-product-name">サンプル商品名</h3>
                <div class="wg-product-rating">
                  <div class="wg-stars">
                    <span class="wg-star">★</span>
                    <span class="wg-star">★</span>
                    <span class="wg-star">★</span>
                    <span class="wg-star">★</span>
                    <span class="wg-star">★</span>
                  </div>
                  <div class="wg-product-price">
                    ¥ <span class="wg-product-price__num">12,000</span>
                    <span class="wg-product-price__tax">（税込）</span>
                  </div>
                </div>
                <button class="wg-btn-cart">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                  </svg>
                  カートに入れる
                </button>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

    </div>
  </section>
</div>

{% schema %}
{
  "name": "WinGrow お買い得品",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "サブタイトル",
      "default": "早い者勝ちの大特価！"
    },
    {
      "type": "text",
      "id": "title",
      "label": "セクションタイトル",
      "default": "お買い得品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション",
      "info": "セール商品のコレクションを選択"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "表示する商品数",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "WinGrow お買い得品"
    }
  ]
}
{% endschema %}
