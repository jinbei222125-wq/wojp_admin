<section class="cart-page" id="CartPage">
  <div class="container">
    <h1 class="cart-page__title">ショッピングカート</h1>

    {%- if cart.item_count > 0 -%}
      <div class="cart-page__layout">
        <!-- カートアイテム -->
        <div class="cart-page__items">
          {%- for item in cart.items -%}
            <div class="cart-item" id="CartItem-{{ item.index | plus: 1 }}">
              <div class="cart-item__img-wrap">
                {%- if item.image -%}
                  <img
                    src="{{ item.image | img_url: '150x150', crop: 'center' }}"
                    alt="{{ item.image.alt | default: item.product.title }}"
                    loading="lazy"
                    width="150" height="150"
                  >
                {%- endif -%}
              </div>
              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="cart-item__price">{{ item.final_price | money }}</p>
                <div class="cart-item__quantity">
                  <button class="quantity-btn quantity-btn--minus" data-line="{{ item.index | plus: 1 }}" aria-label="数量を減らす">−</button>
                  <input
                    type="number"
                    class="cart-item__quantity-input"
                    value="{{ item.quantity }}"
                    min="0"
                    data-line="{{ item.index | plus: 1 }}"
                    aria-label="数量"
                  >
                  <button class="quantity-btn quantity-btn--plus" data-line="{{ item.index | plus: 1 }}" aria-label="数量を増やす">＋</button>
                </div>
              </div>
              <div class="cart-item__total">
                <p>{{ item.final_line_price | money }}</p>
                <a href="{{ routes.cart_change_url }}?line={{ item.index | plus: 1 }}&quantity=0"
                   class="cart-item__remove"
                   aria-label="{{ item.product.title }}を削除">
                  削除
                </a>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- 合計・チェックアウト -->
        <div class="cart-page__summary">
          <div class="cart-summary">
            <h2 class="cart-summary__title">注文内容</h2>
            <div class="cart-summary__row">
              <span>小計</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-summary__note">送料・税は次のステップで計算されます</p>
            <a href="{{ routes.checkout }}" class="btn-checkout">
              レジに進む
            </a>
            <a href="{{ routes.root_url }}" class="btn-continue">
              ← 買い物を続ける
            </a>
          </div>
        </div>
      </div>

    {%- else -%}
      <div class="cart-page__empty">
        <p>カートに商品がありません。</p>
        <a href="{{ routes.root_url }}" class="btn-more-red">商品を見る</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "カート",
  "tag": "section",
  "class": "section-main-cart"
}
{% endschema %}
