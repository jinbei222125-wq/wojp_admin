<section class="section-ranking" id="Ranking-{{ section.id }}">
  <div class="container">
    <div class="section-header">
      <div class="wave-deco" aria-hidden="true">〜〜〜</div>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="ranking-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {%- assign product = block.settings.product -%}
          {%- assign rank = forloop.index -%}
          <div class="product-card ranking-card rank-{{ rank }}" {{ block.shopify_attributes }}>
            <div class="rank-badge rank-badge--{{ rank }}" aria-label="{{ rank }}位">{{ rank }}位</div>
            <div class="product-card__img-wrap">
              {%- if product != blank -%}
                <a href="{{ product.url }}">
                  <img
                    src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
                    alt="{{ product.featured_image.alt | default: product.title }}"
                    loading="lazy"
                    width="400" height="400"
                  >
                </a>
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="product-card__info">
              {%- if product != blank -%}
                <span class="product-card__label">{{ block.settings.label | default: '冷凍' }}</span>
                <h3 class="product-card__name">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <div class="product-card__stars" aria-label="評価5つ星">★★★★★</div>
                <p class="product-card__price">
                  {{ product.price | money }}
                  <span class="product-card__tax">（税込）</span>
                </p>
                <a href="{{ product.url }}?variant={{ product.first_available_variant.id }}"
                   class="btn-cart"
                   data-product-id="{{ product.id }}">
                  カートに入れる
                </a>
              {%- else -%}
                <span class="product-card__label">冷凍</span>
                <h3 class="product-card__name">商品名が入ります</h3>
                <div class="product-card__stars">★★★★★</div>
                <p class="product-card__price">¥ 12,000<span class="product-card__tax">（税込）</span></p>
                <a href="#" class="btn-cart">カートに入れる</a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "人気ランキング",
  "tag": "section",
  "class": "section-ranking",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し",
      "default": "海産専門店厳選食品をご紹介！"
    },
    {
      "type": "text",
      "id": "title",
      "label": "セクションタイトル",
      "default": "人気ランキング"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "ランキング商品",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "商品を選択"
        },
        {
          "type": "text",
          "id": "label",
          "label": "商品ラベル（例：冷凍）",
          "default": "冷凍"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "人気ランキング",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
