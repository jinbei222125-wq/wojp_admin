{% comment %}
  WinGrow お問い合わせページ
  - 連絡先情報 / お問い合わせフォーム
{% endcomment %}

<div class="wg-site">
  <section class="wg-contact">
    <div class="wg-container">

      <nav class="wg-breadcrumb" aria-label="パンくずリスト">
        <ol class="wg-breadcrumb__list">
          <li class="wg-breadcrumb__item">
            <a href="{{ routes.root_url }}" class="wg-breadcrumb__link">トップページ</a>
          </li>
          <li class="wg-breadcrumb__item wg-breadcrumb__item--current">お問い合わせ</li>
        </ol>
      </nav>

      <div class="wg-section-header">
        <p class="wg-section-subtitle">Contact Us</p>
        <h1 class="wg-section-title">お問い合わせ</h1>
      </div>

      <div class="wg-contact__inner">

        {%- comment %} 連絡先情報 {%- endcomment %}
        <div class="wg-contact__info">
          <div class="wg-contact__info-card">
            <div class="wg-guide__info-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.78h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.4a16 16 0 0 0 6.29 6.29l.9-.9a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <h3>電話でのお問い合わせ</h3>
            <p class="wg-contact__phone">011-596-0967</p>
            <p class="wg-contact__hours">受付時間：10:00〜17:00（平日）</p>
          </div>
          <div class="wg-contact__info-card">
            <div class="wg-guide__info-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <h3>メールでのお問い合わせ</h3>
            <p>info@wingrow.jp</p>
            <p class="wg-contact__hours">2営業日以内にご返信いたします</p>
          </div>
        </div>

        {%- comment %} お問い合わせフォーム {%- endcomment %}
        <div class="wg-contact__form-wrap">
          <h2 class="wg-guide__section-title">フォームからのお問い合わせ</h2>

          {%- form 'contact' -%}
            {%- if form.posted_successfully? -%}
              <div class="wg-form-success">
                <p>お問い合わせありがとうございます。内容を確認の上、ご連絡させていただきます。</p>
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="wg-form-error" role="alert">
                <ul>
                  {%- for error in form.errors -%}
                    <li>{{ form.errors.messages[error] }}</li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            <div class="wg-form-row">
              <div class="wg-form-group">
                <label class="wg-form-label" for="ContactName">お名前 <span class="wg-form-required">必須</span></label>
                <input type="text" name="contact[name]" id="ContactName" class="wg-form-input"
                       placeholder="山田 太郎" required>
              </div>
              <div class="wg-form-group">
                <label class="wg-form-label" for="ContactEmail">メールアドレス <span class="wg-form-required">必須</span></label>
                <input type="email" name="contact[email]" id="ContactEmail" class="wg-form-input"
                       placeholder="example@email.com" required>
              </div>
            </div>

            <div class="wg-form-group">
              <label class="wg-form-label" for="ContactPhone">電話番号</label>
              <input type="tel" name="contact[phone]" id="ContactPhone" class="wg-form-input"
                     placeholder="090-1234-5678">
            </div>

            <div class="wg-form-group">
              <label class="wg-form-label" for="ContactSubject">お問い合わせ種別</label>
              <div class="wg-product__option-select-wrap">
                <select name="contact[subject]" id="ContactSubject" class="wg-form-input wg-product__option-select">
                  <option value="">選択してください</option>
                  <option value="商品について">商品について</option>
                  <option value="配送について">配送について</option>
                  <option value="返品・交換について">返品・交換について</option>
                  <option value="その他">その他</option>
                </select>
                <svg class="wg-select-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
            </div>

            <div class="wg-form-group">
              <label class="wg-form-label" for="ContactBody">お問い合わせ内容 <span class="wg-form-required">必須</span></label>
              <textarea name="contact[body]" id="ContactBody" class="wg-form-input wg-form-textarea"
                        rows="6" placeholder="お問い合わせ内容をご記入ください" required></textarea>
            </div>

            <button type="submit" class="wg-btn-cart wg-btn-auth">
              送信する
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </button>
          {%- endform -%}
        </div>

      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "WG お問い合わせ",
  "settings": []
}
{% endschema %}
