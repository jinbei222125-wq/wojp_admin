{% comment %}
  WinGrow お知らせ＆公式SNSセクション
  - 2カラムレイアウト（お知らせ左 / SNS右）
  - お知らせ：ブログ記事一覧 or 静的テキスト
  - SNS：Facebook / X / Instagram / YouTube / TikTok
{% endcomment %}

{%- liquid
  assign news_blog = blogs[section.settings.blog]
  assign articles_to_show = section.settings.articles_count | default: 3
-%}

<div class="wg-site">
  <section class="wg-news-sns">
    <div class="wg-container">
      <div class="wg-news-sns__inner">

        {%- comment %} お知らせ {%- endcomment %}
        <div class="wg-news-section">
          <h2 class="wg-news__title">{{ section.settings.news_title }}</h2>
          <ul class="wg-news__list">
            {%- if news_blog != blank -%}
              {%- for article in news_blog.articles limit: articles_to_show -%}
                <li class="wg-news__item">
                  <a href="{{ article.url }}">
                    <p class="wg-news__date">{{ article.published_at | date: '%Y.%m.%d' }}</p>
                    <p class="wg-news__item-text">{{ article.title | escape }}</p>
                  </a>
                </li>
              {%- endfor -%}
            {%- else -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'news_item' -%}
                  <li class="wg-news__item" {{ block.shopify_attributes }}>
                    <a href="{{ block.settings.url | default: '#' }}">
                      <p class="wg-news__date">{{ block.settings.date }}</p>
                      <p class="wg-news__item-text">{{ block.settings.text }}</p>
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </ul>
          <a href="{{ section.settings.news_more_url | default: '#' }}" class="wg-btn-navy">
            {{ section.settings.news_btn_text }}
            <span class="wg-btn-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </span>
          </a>
        </div>

        {%- comment %} 公式SNS {%- endcomment %}
        <div class="wg-sns-section">
          <h2 class="wg-sns__title">{{ section.settings.sns_title }}</h2>
          <p class="wg-sns__subtitle">{{ section.settings.sns_subtitle }}</p>
          <div class="wg-sns-grid">

            {%- comment %} Facebook 公式アイコン {%- endcomment %}
            <a href="{{ section.settings.facebook_url | default: '#' }}" class="wg-sns-btn wg-sns-btn--facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.268h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
              </svg>
              Facebook
            </a>

            {%- comment %} X（旧Twitter）公式アイコン {%- endcomment %}
            <a href="{{ section.settings.twitter_url | default: '#' }}" class="wg-sns-btn wg-sns-btn--twitter" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              X（旧Twitter）
            </a>

            {%- comment %} Instagram 公式アイコン（fillベース） {%- endcomment %}
            <a href="{{ section.settings.instagram_url | default: '#' }}" class="wg-sns-btn wg-sns-btn--instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              Instagram
            </a>

            {%- comment %} YouTube 公式アイコン {%- endcomment %}
            <a href="{{ section.settings.youtube_url | default: '#' }}" class="wg-sns-btn wg-sns-btn--youtube" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              YouTube
            </a>

            {%- comment %} TikTok 公式アイコン {%- endcomment %}
            <a href="{{ section.settings.tiktok_url | default: '#' }}" class="wg-sns-btn wg-sns-btn--tiktok" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
              TikTok
            </a>

          </div>
        </div>

      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "WinGrow お知らせ＆SNS",
  "blocks": [
    {
      "type": "news_item",
      "name": "お知らせ（静的）",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "日付",
          "default": "2025.08.01"
        },
        {
          "type": "text",
          "id": "text",
          "label": "テキスト",
          "default": "お知らせのテキストを入力してください"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "お知らせ設定"
    },
    {
      "type": "text",
      "id": "news_title",
      "label": "お知らせタイトル",
      "default": "お知らせ"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "ブログ（ブログ記事を自動取得）",
      "info": "未設定の場合はブロックの静的テキストを使用"
    },
    {
      "type": "range",
      "id": "articles_count",
      "label": "表示する記事数",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "news_btn_text",
      "label": "一覧ボタンのテキスト",
      "default": "一覧を見る"
    },
    {
      "type": "url",
      "id": "news_more_url",
      "label": "一覧ページのURL"
    },
    {
      "type": "header",
      "content": "SNS設定"
    },
    {
      "type": "text",
      "id": "sns_title",
      "label": "SNSタイトル",
      "default": "公式SNS"
    },
    {
      "type": "text",
      "id": "sns_subtitle",
      "label": "SNSサブタイトル",
      "default": "最新情報、旬の商品の情報など随時更新しています。"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X（Twitter）URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ],
  "presets": [
    {
      "name": "WinGrow お知らせ＆SNS",
      "blocks": [
        {
          "type": "news_item",
          "settings": {
            "date": "2025.08.01",
            "text": "テキストテキストテキストテキストテキストテキストテキストテキスト"
          }
        },
        {
          "type": "news_item",
          "settings": {
            "date": "2025.08.01",
            "text": "テキストテキストテキストテキストテキストテキストテキストテキスト"
          }
        },
        {
          "type": "news_item",
          "settings": {
            "date": "2025.08.01",
            "text": "テキストテキストテキストテキストテキストテキストテキストテキスト"
          }
        }
      ]
    }
  ]
}
{% endschema %}
