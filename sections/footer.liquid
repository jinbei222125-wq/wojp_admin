<!-- フッターナビバー -->
<div class="footer-nav-bar">
  <div class="container">
    <div class="footer-nav-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_item' -%}
          <a href="{{ block.settings.url }}" class="footer-nav-item" {{ block.shopify_attributes }}>
            <div class="footer-nav-icon">
              {%- if block.settings.icon != blank -%}
                <img src="{{ block.settings.icon | img_url: '60x60' }}" alt="{{ block.settings.label }}">
              {%- else -%}
                <span class="footer-nav-emoji">{{ block.settings.emoji }}</span>
              {%- endif -%}
            </div>
            <p>{{ block.settings.label }}</p>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- メインフッター -->
<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer__top">

      <!-- ロゴ -->
      <div class="footer__logo-col">
        {%- if section.settings.footer_logo != blank -%}
          <img src="{{ section.settings.footer_logo | img_url: '160x' }}" alt="{{ shop.name }}" class="footer__logo-img">
        {%- else -%}
          <span class="footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.footer_description != blank -%}
          <p class="footer__description">{{ section.settings.footer_description }}</p>
        {%- endif -%}
      </div>

      <!-- リンク群 -->
      <div class="footer__links-grid">
        {%- for i in (1..4) -%}
          {%- assign menu_setting = 'footer_menu_' | append: i -%}
          {%- assign title_setting = 'footer_menu_title_' | append: i -%}
          {%- assign menu = section.settings[menu_setting] -%}
          {%- if menu != blank -%}
            <div class="footer__links-col">
              <h4 class="footer__links-title">{{ section.settings[title_setting] }}</h4>
              <ul>
                {%- for link in linklists[menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    <div class="footer__bottom">
      <!-- 決済アイコン -->
      <div class="footer__payment">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
        {%- endfor -%}
      </div>
      <!-- コピーライト -->
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

