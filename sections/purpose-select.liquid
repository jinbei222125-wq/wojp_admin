<section class="section-purpose" id="Purpose-{{ section.id }}">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.subheading != blank -%}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="purpose-layout">
      <div class="purpose-left">
        <!-- シーンで探す -->
        <div class="purpose-scene">
          <h3 class="purpose-scene-title">シーンで探す</h3>
          <div class="purpose-tags">
            {%- assign scene_tags = section.settings.scene_tags | split: ',' -%}
            {%- for tag in scene_tags -%}
              <a href="{{ routes.collections_url }}/all?filter.p.tag={{ tag | strip | url_encode }}" class="purpose-tag">
                {{ tag | strip }}
              </a>
            {%- endfor -%}
          </div>
        </div>

        <!-- 価格で探す -->
        <div class="purpose-price">
          <h3 class="purpose-scene-title">価格で探す</h3>
          <div class="purpose-tags">
            {%- assign price_ranges = section.settings.price_ranges | split: ',' -%}
            {%- assign price_labels = section.settings.price_labels | split: ',' -%}
            {%- for range in price_ranges -%}
              {%- assign range_parts = range | strip | split: '-' -%}
              <a href="{{ routes.collections_url }}/all?filter.v.price.lte={{ range_parts[1] | strip }}" class="purpose-tag">
                {{ price_labels[forloop.index0] | strip }}
              </a>
            {%- endfor -%}
          </div>
        </div>
      </div>

      <div class="purpose-right">
        {%- for block in section.blocks -%}
          {%- if block.type == 'image_link' -%}
            <a href="{{ block.settings.url }}" class="purpose-img-wrap" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | img_url: '400x400', crop: 'center' }}"
                  alt="{{ block.settings.label }}"
                  loading="lazy"
                  width="400" height="400"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <div class="purpose-img-label">{{ block.settings.label }}</div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "目的で選ぶ",
  "tag": "section",
  "class": "section-purpose",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し",
      "default": "記念日や旅行にぴったり！"
    },
    {
      "type": "text",
      "id": "title",
      "label": "タイトル",
      "default": "目的で選ぶ"
    },
    {
      "type": "text",
      "id": "scene_tags",
      "label": "シーンタグ（カンマ区切り）",
      "default": "誕生日プレゼント,内祝い,お中元・お歳暮,記念日・特別な日"
    },
    {
      "type": "text",
      "id": "price_ranges",
      "label": "価格範囲（カンマ区切り、例: 0-5000,0-10000）",
      "default": "0-5000,0-10000,0-15000,0-20000"
    },
    {
      "type": "text",
      "id": "price_labels",
      "label": "価格ラベル（カンマ区切り）",
      "default": "送料無料 〜¥5000,〜¥10000,〜¥15000,〜¥20000"
    }
  ],
  "blocks": [
    {
      "type": "image_link",
      "name": "画像リンク",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "label",
          "label": "ラベルテキスト",
          "default": "贈り物におすすめ"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンクURL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "目的で選ぶ",
      "blocks": [
        { "type": "image_link", "settings": { "label": "贈り物におすすめ" } },
        { "type": "image_link", "settings": { "label": "新商品" } }
      ]
    }
  ]
}
{% endschema %}
