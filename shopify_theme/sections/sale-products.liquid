<section class="sale-products" id="sale-products">
  <div class="container">
    <div class="section-header">
      <h2 class="section-header__heading">
        <span class="section-header__icon">💰</span>
        {{ section.settings.heading }}
      </h2>
    </div>

    {% assign sale_collection = collections[section.settings.collection] %}

    {% if sale_collection != empty and sale_collection.products.size > 0 %}
      <div class="product-grid">
        {% for product in sale_collection.products limit: section.settings.products_to_show %}
          <div class="product-card">
            {% if product.compare_at_price > product.price %}
              <div class="product-card__badge product-card__badge--sale">SALE</div>
            {% endif %}

            <a href="{{ product.url }}" class="product-card__image-link">
              {% if product.featured_image != blank %}
                <img
                  src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
                  alt="{{ product.featured_image.alt | default: product.title }}"
                  class="product-card__image"
                  width="400"
                  height="400"
                  loading="lazy"
                >
              {% else %}
                <div class="product-card__image-placeholder">
                  <span>商品画像</span>
                </div>
              {% endif %}
            </a>

            <div class="product-card__info">
              <h3 class="product-card__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <div class="product-card__price">
                {% if customer and customer.tags contains 'member' %}
                  {% assign member_price = product.metafields.custom.member_price %}
                  {% if member_price != blank %}
                    <span class="price price--member">{{ member_price | money }}</span>
                    <span class="price price--compare">{{ product.price | money }}</span>
                  {% else %}
                    <span class="price price--member">{{ product.price | money }}</span>
                  {% endif %}
                  <span class="price-badge price-badge--member">会員価格</span>
                {% else %}
                  <span class="price price--regular">{{ product.price | money }}</span>
                  {% assign member_price = product.metafields.custom.member_price %}
                  {% if member_price != blank %}
                    {% assign saving = product.price | minus: member_price %}
                    <p class="price-member-appeal">会員なら <strong>{{ member_price | money }}</strong> <span class="price-saving">（▼ {{ saving | money }}）</span></p>
                  {% endif %}
                {% endif %}
              </div>

              <form action="/cart/add" method="post" class="product-card__form">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button
                  type="submit"
                  class="btn btn--primary btn--full product-card__add-btn"
                  {% unless product.available %}disabled{% endunless %}
                >
                  {% if product.available %}カートに入れる{% else %}売り切れ{% endif %}
                </button>
              </form>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="section-footer">
        <a href="{{ sale_collection.url }}" class="btn btn--outline">お買い得商品をすべて見る</a>
      </div>

    {% else %}
      <!-- ダミー表示 -->
      <div class="product-grid">
        {% for i in (1..4) %}
          <div class="product-card product-card--dummy">
            <div class="product-card__badge product-card__badge--sale">SALE</div>
            <div class="product-card__image-placeholder"><span>商品画像</span></div>
            <div class="product-card__info">
              <h3 class="product-card__title">商品名（ダミー）</h3>
              <div class="product-card__price">
                <span class="price price--regular">¥8,000</span>
                <p class="price-member-appeal">会員なら <strong>¥6,500</strong> <span class="price-saving">（▼ ¥1,500）</span></p>
              </div>
              <button class="btn btn--primary btn--full">カートに入れる</button>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "お買い得商品",
  "tag": "section",
  "class": "section-sale-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "お買い得商品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "表示商品数",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "お買い得商品"
    }
  ]
}
{% endschema %}
