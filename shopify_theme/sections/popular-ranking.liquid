<section class="popular-ranking" id="popular-ranking">
  <div class="container">
    <div class="section-header">
      <h2 class="section-header__heading">
        <span class="section-header__icon">🏆</span>
        {{ section.settings.heading }}
      </h2>
      {% if section.settings.subheading != blank %}
        <p class="section-header__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {% assign ranking_collection = collections[section.settings.collection] %}

    {% if ranking_collection != empty and ranking_collection.products.size > 0 %}
      <div class="product-grid product-grid--ranking">
        {% for product in ranking_collection.products limit: section.settings.products_to_show %}
          <div class="product-card product-card--ranking">
            <!-- ランキングバッジ -->
            <div class="product-card__rank">
              {% case forloop.index %}
                {% when 1 %}
                  <span class="rank-badge rank-badge--gold">1位</span>
                {% when 2 %}
                  <span class="rank-badge rank-badge--silver">2位</span>
                {% when 3 %}
                  <span class="rank-badge rank-badge--bronze">3位</span>
                {% else %}
                  <span class="rank-badge">{{ forloop.index }}位</span>
              {% endcase %}
            </div>

            <!-- 商品画像 -->
            <a href="{{ product.url }}" class="product-card__image-link">
              {% if product.featured_image != blank %}
                <img
                  src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
                  alt="{{ product.featured_image.alt | default: product.title }}"
                  class="product-card__image"
                  width="400"
                  height="400"
                  loading="lazy"
                >
              {% else %}
                <div class="product-card__image-placeholder">
                  <span>商品画像</span>
                </div>
              {% endif %}
            </a>

            <!-- 商品情報 -->
            <div class="product-card__info">
              <h3 class="product-card__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <!-- 価格表示（会員/非会員で切替） -->
              <div class="product-card__price">
                {% if customer and customer.tags contains 'member' %}
                  <!-- 会員価格 -->
                  {% assign member_price = product.metafields.custom.member_price %}
                  {% if member_price != blank %}
                    <span class="price price--member">{{ member_price | money }}</span>
                    <span class="price price--compare">{{ product.price | money }}</span>
                  {% else %}
                    <span class="price price--member">{{ product.price | money }}</span>
                  {% endif %}
                  <span class="price-badge price-badge--member">会員価格</span>
                {% else %}
                  <!-- 通常価格 + 会員価格訴求 -->
                  <span class="price price--regular">{{ product.price | money }}</span>
                  {% assign member_price = product.metafields.custom.member_price %}
                  {% if member_price != blank %}
                    {% assign saving = product.price | minus: member_price %}
                    <p class="price-member-appeal">
                      会員なら <strong>{{ member_price | money }}</strong>
                      <span class="price-saving">（▼ {{ saving | money }} お得）</span>
                    </p>
                  {% endif %}
                {% endif %}
              </div>

              <!-- カートに追加 -->
              <form action="/cart/add" method="post" class="product-card__form">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button
                  type="submit"
                  class="btn btn--primary btn--full product-card__add-btn"
                  {% unless product.available %}disabled{% endunless %}
                >
                  {% if product.available %}
                    カートに入れる
                  {% else %}
                    売り切れ
                  {% endif %}
                </button>
              </form>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="section-footer">
        <a href="{{ ranking_collection.url }}" class="btn btn--outline">
          ランキングをすべて見る
        </a>
      </div>

    {% else %}
      <!-- コレクション未設定時のダミー表示 -->
      <div class="product-grid product-grid--ranking">
        {% for i in (1..8) %}
          <div class="product-card product-card--ranking product-card--dummy">
            <div class="product-card__rank">
              <span class="rank-badge {% if i == 1 %}rank-badge--gold{% elsif i == 2 %}rank-badge--silver{% elsif i == 3 %}rank-badge--bronze{% endif %}">{{ i }}位</span>
            </div>
            <div class="product-card__image-placeholder">
              <span>商品画像</span>
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">商品名（ダミー）</h3>
              <div class="product-card__price">
                <span class="price price--regular">¥12,000</span>
                <p class="price-member-appeal">会員なら <strong>¥9,800</strong> <span class="price-saving">（▼ ¥2,200 お得）</span></p>
              </div>
              <button class="btn btn--primary btn--full product-card__add-btn">カートに入れる</button>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "人気ランキング",
  "tag": "section",
  "class": "section-popular-ranking",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "人気ランキング"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し",
      "default": "今週よく売れている商品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "表示商品数",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "人気ランキング"
    }
  ]
}
{% endschema %}
