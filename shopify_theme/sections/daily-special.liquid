<section class="daily-special" id="daily-special">
  <div class="container">
    <div class="section-header">
      <h2 class="section-header__heading">
        <span class="section-header__icon">📅</span>
        {{ section.settings.heading }}
      </h2>
      {% if section.settings.subheading != blank %}
        <p class="section-header__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="daily-special__inner">
      <!-- 特集商品（メタフィールドまたはコレクションから取得） -->
      {% assign special_collection = collections[section.settings.collection] %}

      {% if special_collection != empty and special_collection.products.size > 0 %}
        {% assign special_product = special_collection.products.first %}
        <div class="daily-special__featured">
          <div class="daily-special__image-wrap">
            {% if special_product.featured_image != blank %}
              <img
                src="{{ special_product.featured_image | img_url: '800x600', crop: 'center' }}"
                alt="{{ special_product.title }}"
                class="daily-special__image"
                width="800"
                height="600"
                loading="lazy"
              >
            {% else %}
              <div class="daily-special__image-placeholder">
                <span>特集商品画像</span>
              </div>
            {% endif %}
            <div class="daily-special__badge">本日の特集</div>
          </div>

          <div class="daily-special__content">
            <p class="daily-special__label">{{ section.settings.feature_label }}</p>
            <h3 class="daily-special__product-title">{{ special_product.title }}</h3>
            <p class="daily-special__description">{{ special_product.description | strip_html | truncate: 150 }}</p>

            <div class="daily-special__price">
              {% if customer and customer.tags contains 'member' %}
                {% assign member_price = special_product.metafields.custom.member_price %}
                {% if member_price != blank %}
                  <span class="price price--member">{{ member_price | money }}</span>
                  <span class="price price--compare">{{ special_product.price | money }}</span>
                {% else %}
                  <span class="price price--member">{{ special_product.price | money }}</span>
                {% endif %}
              {% else %}
                <span class="price price--regular">{{ special_product.price | money }}</span>
                {% assign member_price = special_product.metafields.custom.member_price %}
                {% if member_price != blank %}
                  {% assign saving = special_product.price | minus: member_price %}
                  <p class="price-member-appeal">会員なら <strong>{{ member_price | money }}</strong> <span class="price-saving">（▼ {{ saving | money }} お得）</span></p>
                {% endif %}
              {% endif %}
            </div>

            <a href="{{ special_product.url }}" class="btn btn--primary">
              商品を見る
            </a>
          </div>
        </div>

      {% else %}
        <!-- ダミー表示 -->
        <div class="daily-special__featured">
          <div class="daily-special__image-wrap">
            <div class="daily-special__image-placeholder">
              <span>特集商品画像</span>
            </div>
            <div class="daily-special__badge">本日の特集</div>
          </div>
          <div class="daily-special__content">
            <p class="daily-special__label">今日のイチオシ</p>
            <h3 class="daily-special__product-title">タラバガニ ビートロ 800g</h3>
            <p class="daily-special__description">
              極太肉で比例的なボリューム感、プリプリ食感と適度な甘み。ギフトにも喜ばれる高級感。
              専門店より手頃な価格でお届けします。
            </p>
            <div class="daily-special__price">
              <span class="price price--regular">¥12,000</span>
              <p class="price-member-appeal">会員なら <strong>¥9,800</strong> <span class="price-saving">（▼ ¥2,200 お得）</span></p>
            </div>
            <a href="#" class="btn btn--primary">商品を見る</a>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "日替わり特集",
  "tag": "section",
  "class": "section-daily-special",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "日替わり特集"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し",
      "default": "毎日更新！今日のおすすめ"
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "特集ラベル",
      "default": "今日のイチオシ"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "特集コレクション"
    }
  ],
  "presets": [
    {
      "name": "日替わり特集"
    }
  ]
}
{% endschema %}
