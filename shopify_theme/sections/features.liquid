<section class="features" id="features">
  <div class="container">
    <div class="section-header">
      <h2 class="section-header__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="features-grid">
      {% for block in section.blocks %}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-card__icon">{{ block.settings.icon }}</div>
          <h3 class="feature-card__title">{{ block.settings.title }}</h3>
          <p class="feature-card__description">{{ block.settings.description }}</p>
        </div>
      {% else %}
        <!-- デフォルト特徴 -->
        <div class="feature-card">
          <div class="feature-card__icon">🦀</div>
          <h3 class="feature-card__title">北海道直送の新鮮さ</h3>
          <p class="feature-card__description">北海道の漁師・産地から直接仕入れた鮮度抜群の海産物をお届けします。</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">❄️</div>
          <h3 class="feature-card__title">冷凍便で鮮度を保持</h3>
          <p class="feature-card__description">佐川急便の飛脚クール便（冷凍）で、解凍するまで鮮度を保ちます。</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">💰</div>
          <h3 class="feature-card__title">会員なら常に卸値</h3>
          <p class="feature-card__description">月額500円の会員登録で、全商品を卸値（会員価格）でお買い求めいただけます。</p>
        </div>
        <div class="feature-card">
          <div class="feature-card__icon">🚚</div>
          <h3 class="feature-card__title">10,000円以上送料無料</h3>
          <p class="feature-card__description">10,000円以上のご購入で送料無料。まとめ買いがお得です。</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "特徴紹介",
  "tag": "section",
  "class": "section-features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "kamuy-shopが選ばれる理由"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "特徴",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "アイコン（絵文字）",
          "default": "🦀"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明文"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "特徴紹介"
    }
  ]
}
{% endschema %}
